# =============================================================================
# Local environment template — copy to `.env.local` and fill in values.
# Production values live in wrangler.jsonc `vars` + `wrangler secret put`.
# =============================================================================

# --- Payload core ---
PAYLOAD_SECRET=YOUR_PAYLOAD_SECRET
NEXT_PUBLIC_SITE_URL=http://local.payloadcms.com:3000
NEXT_PUBLIC_CLOUD_CMS_URL=http://cloud.local.payloadcms.com:8001

# --- Telemetry opt-outs (mirror wrangler.jsonc vars) ---
NEXT_TELEMETRY_DISABLED=1
PAYLOAD_DISABLE_TELEMETRY=true
WRANGLER_SEND_METRICS=false
DO_NOT_TRACK=1

# --- Cloudflare Turnstile (replaces Google reCAPTCHA) ---
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Cloudflare Web Analytics (replaces GA + FB Pixel) ---
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=

# --- Cloudflare send_email defaults (binding is set in wrangler.jsonc) ---
MAIL_FROM_ADDRESS=info@payloadcms.com
MAIL_FROM_NAME=Payload

# --- Draft preview / revalidation ---
NEXT_PRIVATE_DRAFT_SECRET=demo_draft_secret
NEXT_PRIVATE_REVALIDATION_KEY=demo_revalidation_key

# --- GitHub (docs sync + release-post generator) ---
GITHUB_ACCESS_TOKEN=

# --- Robots / sitemap ---
NEXT_PUBLIC_IS_LIVE=
SITEMAP_URL=

# --- HubSpot form submissions ---
NEXT_PRIVATE_HUBSPOT_PORTAL_KEY=

# --- Cloud platform (Stripe / GitHub OAuth) ---
NEXT_PUBLIC_GITHUB_REDIRECT_URI=http://local.payloadcms.com:3000/gh
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# --- Discord (community-help sync) ---
DISCORD_TOKEN=
DISCORD_SCRAPE_CHANNEL_ID=

# --- Newsletter ---
NEXT_PUBLIC_NEWSLETTER_FORM_ID=

# --- Build skip toggles ---
NEXT_PUBLIC_SKIP_BUILD_DOCS=
NEXT_PUBLIC_SKIP_BUILD_HELPS=

# --- Redeploy webhook (kept as VERCEL_* name for backwards compat) ---
VERCEL_REDEPLOY_URL=

# --- Release-post creation secret (shared with GitHub Actions) ---
PAYLOAD_RELEASE_SECRET=

# --- Sentry (optional; plugin no-ops without this) ---
SENTRY_DSN=

# --- Misc ---
NEXT_PUBLIC_OMIT_CLOUD_ERRORS=false
