{
  "name": "payload-website",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:app": "opennextjs-cloudflare build --env=$CLOUDFLARE_ENV && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "rm -rf .next && rm -rf .open-next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "pnpm run generate:types:cloudflare && pnpm run generate:types:payload",
    "generate:types:cloudflare": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "generate:types:payload": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "pnpm install --ignore-workspace",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "generate:llms": "payload run src/scripts/generateLLMs.ts",
    "sync-translations": "node scripts/sync-translations.mjs",
    "build:skipDocs": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "postbuild": "next-sitemap --config ./next-sitemap.config.cjs",
    "analyze": "ANALYZE=true next build",
    "prettier:fix": "prettier --write .",
    "migrate-lexical-script": "payload run ./src/migrate.ts",
    "migrate:local": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:remote": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation payload migrate"
  },
  "dependencies": {
    "@faceless-ui/collapsibles": "2.0.0-beta.1",
    "@faceless-ui/css-grid": "1.3.0-rc.0",
    "@faceless-ui/modal": "3.0.0",
    "@faceless-ui/mouse-info": "2.0.0-beta.1",
    "@faceless-ui/scroll-info": "2.0.0",
    "@faceless-ui/slider": "2.0.0-beta.1",
    "@faceless-ui/window-info": "3.0.1",
    "@opennextjs/cloudflare": "^1.19.9",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-d1-sqlite": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-import-export": "3.84.1",
    "@payloadcms/plugin-mcp": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-sentry": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-r2": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-portal": "^1.1.10",
    "@radix-ui/react-tabs": "^1.1.13",
    "@stripe/react-stripe-js": "^6.3.0",
    "@stripe/stripe-js": "^9.5.0",
    "cheerio": "^1.2.0",
    "cross-env": "10.1.0",
    "discord-markdown": "^2.5.1",
    "flatley": "^5.2.0",
    "framer-motion": "12.38.0",
    "geist": "^1.7.0",
    "graphql": "16.14.0",
    "gray-matter": "^4.0.3",
    "mimetext": "^3.0.28",
    "next": "16.2.6",
    "next-sitemap": "^4.2.3",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.4.1",
    "qs-esm": "8.0.1",
    "react": "19.2.6",
    "react-cookie": "^8.1.2",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "react-select": "5.10.2",
    "react-transition-group": "^4.4.5",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "sonner": "2.0.7",
    "stripe": "^22.1.1",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@next/bundle-analyzer": "16.2.6",
    "@octokit/types": "^16.0.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/eslint-plugin": "3.28.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "25.7.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cli-progress": "^3.12.0",
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "eslint": "9.36.0",
    "prettier": "3.8.3",
    "typescript": "5.8.3",
    "wrangler": "^4.90.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "workerd"
    ],
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "cookie@<0.7.0": ">=0.7.0",
      "@eslint/plugin-kit@<0.3.4": ">=0.3.4",
      "lodash@>=4.0.0 <=4.17.22": ">=4.17.23",
      "undici@<6.23.0": ">=6.23.0",
      "undici@>=7.0.0 <7.18.2": ">=7.18.2",
      "qs@>=6.7.0 <=6.14.1": ">=6.14.2",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@>=9.0.0 <9.0.6": ">=9.0.6",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@<3.1.4": ">=3.1.4",
      "ajv@<6.14.0": ">=6.14.0",
      "qs@<6.14.1": ">=6.14.1",
      "flatted@<3.4.0": ">=3.4.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "undici@>=6.0.0 <6.24.0": ">=6.24.0",
      "undici@<6.24.0": ">=6.24.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "picomatch@<2.3.2": ">=2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "dompurify@>=3.1.3 <=3.3.1": ">=3.3.2",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "dompurify@<=3.3.1": ">=3.3.2",
      "dompurify@<=3.3.3": ">=3.4.0",
      "postcss@<8.5.10": ">=8.5.10",
      "immutable@>=4.0.0-rc.1 <4.3.8": ">=4.3.8",
      "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
      "dompurify@<3.4.0": ">=3.4.0",
      "dompurify@>=1.0.10 <3.4.0": ">=3.4.0",
      "dompurify@>=3.0.1 <3.4.0": ">=3.4.0",
      "uuid@>=11.0.0 <11.1.1": ">=11.1.1",
      "dompurify@<3.3.2": ">=3.3.2",
      "fast-uri@<=3.1.0": ">=3.1.1",
      "fast-uri@<=3.1.1": ">=3.1.2"
    }
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0",
  "cloudflare": {
    "bindings": {
      "PAYLOAD_SECRET": {
        "description": "Required. Random string used to sign cookies/JWTs. Generate with `openssl rand -hex 32`."
      },
      "TURNSTILE_SECRET_KEY": {
        "description": "Optional. Server-side key for Cloudflare Turnstile form CAPTCHAs. Leave blank to disable. Pair with the public NEXT_PUBLIC_TURNSTILE_SITE_KEY var."
      },
      "NEXT_PUBLIC_TURNSTILE_SITE_KEY": {
        "description": "Optional. Public site key for Cloudflare Turnstile (visible to browsers). Leave blank to disable."
      },
      "NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN": {
        "description": "Optional. Beacon token from Cloudflare Web Analytics dashboard. Leave blank to disable analytics."
      },
      "STRIPE_SECRET_KEY": {
        "description": "Optional. Stripe API secret (server-side). Leave blank if Stripe routes aren't used."
      },
      "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY": {
        "description": "Optional. Stripe publishable key (browser-side). Leave blank if Stripe routes aren't used."
      },
      "GITHUB_ACCESS_TOKEN": {
        "description": "Optional. Personal access token used by docs/release-post sync. Leave blank to disable."
      },
      "NEXT_PRIVATE_HUBSPOT_PORTAL_KEY": {
        "description": "Optional. Forwards form submissions to HubSpot. Leave blank to disable."
      },
      "DISCORD_TOKEN": {
        "description": "Optional. Bot token used to sync community-help threads. Leave blank to disable."
      },
      "SENTRY_DSN": {
        "description": "Optional. Enables @payloadcms/plugin-sentry. Leave blank to disable error reporting."
      },
      "VERCEL_REDEPLOY_URL": {
        "description": "Optional. Webhook hit by the admin 'Redeploy' button (any HTTP webhook works — Cloudflare Workers Builds deploy hook, GitHub Actions, etc.). Leave blank to hide the button."
      }
    }
  }
}
