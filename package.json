{
  "name": "payload-website",
  "version": "1.0.4",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "bash scripts/setup.sh",
    "sync-translations": "node scripts/sync-translations.mjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "generate:llms": "payload run src/scripts/generateLLMs.ts",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:skipDocs": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "cf:build": "pnpm generate:llms && pnpm run deploy:database && opennextjs-cloudflare build",
    "postbuild": "next-sitemap --config ./next-sitemap.config.cjs",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "prettier:fix": "prettier --write .",
    "migrate-lexical-script": "payload run ./src/migrate.ts",
    "migrate:local": "cross-env NODE_OPTIONS=--no-deprecation payload migrate",
    "migrate:remote": "cross-env NODE_ENV=production NODE_OPTIONS=--no-deprecation payload migrate",
    "deploy": "pnpm run deploy:database && pnpm run deploy:app",
    "deploy:database": "cross-env NODE_ENV=production PAYLOAD_SECRET=ignore payload migrate --force-accept-warning && wrangler d1 execute D1 --command 'PRAGMA optimize' --env=$CLOUDFLARE_ENV --remote",
    "deploy:app": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env=$CLOUDFLARE_ENV",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env=$CLOUDFLARE_ENV",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@faceless-ui/collapsibles": "^2.0.0-beta.0",
    "@faceless-ui/css-grid": "1.3.0-rc.0",
    "@faceless-ui/modal": "3.0.0-beta.2",
    "@faceless-ui/mouse-info": "2.0.0-beta.0",
    "@faceless-ui/scroll-info": "2.0.0",
    "@faceless-ui/slider": "2.0.0-beta.0",
    "@faceless-ui/window-info": "3.0.1",
    "@opennextjs/cloudflare": "^1.19.9",
    "@payloadcms/admin-bar": "3.84.1",
    "@payloadcms/db-d1-sqlite": "3.84.1",
    "@payloadcms/live-preview-react": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/plugin-form-builder": "3.84.1",
    "@payloadcms/plugin-import-export": "3.84.1",
    "@payloadcms/plugin-mcp": "3.84.1",
    "@payloadcms/plugin-nested-docs": "3.84.1",
    "@payloadcms/plugin-redirects": "3.84.1",
    "@payloadcms/plugin-search": "3.84.1",
    "@payloadcms/plugin-sentry": "3.84.1",
    "@payloadcms/plugin-seo": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/storage-r2": "3.84.1",
    "@payloadcms/translations": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@radix-ui/react-accordion": "^1.2.1",
    "@radix-ui/react-portal": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.1",
    "@stripe/react-stripe-js": "^3.1.1",
    "@stripe/stripe-js": "^1.47.0",
    "cheerio": "^1.0.0-rc.12",
    "cross-env": "7.0.3",
    "discord-markdown": "^2.5.1",
    "flatley": "^5.2.0",
    "framer-motion": "12.0.0-alpha.2",
    "geist": "^1.3.1",
    "graphql": "16.8.1",
    "gray-matter": "^4.0.3",
    "mimetext": "^3.0.27",
    "next": "16.2.6",
    "next-sitemap": "^4.0.6",
    "payload": "3.84.1",
    "prism-react-renderer": "^2.3.1",
    "qs-esm": "7.0.2",
    "react": "19.2.6",
    "react-cookie": "^4.1.1",
    "react-dom": "19.2.6",
    "react-markdown": "^9.0.1",
    "react-select": "5.9.0",
    "react-transition-group": "^4.4.5",
    "remark-gfm": "^4.0.0",
    "sass": "^1.55.0",
    "sonner": "1.7.0",
    "stripe": "^11.11.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.3.4",
    "@octokit/types": "^9.0.0",
    "@cloudflare/workers-types": "^4.20250129.0",
    "@payloadcms/eslint-config": "3.28.0",
    "@payloadcms/eslint-plugin": "3.28.0",
    "@types/cli-progress": "^3.11.0",
    "@types/node": "22.10.2",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "cli-progress": "^3.11.2",
    "discord.js": "^14.7.1",
    "dotenv": "^16.4.7",
    "eslint": "9.22.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@sentry/cli",
      "esbuild",
      "workerd"
    ]
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
